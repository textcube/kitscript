{
  "manifest_version": 3,
  "name": "Quiz Baker ChatGPT Helper",
  "version": "0.2.0",
  "description": "Load browser_jobs.json, fill prompt into ChatGPT, and download generated images with target filenames.",
  "permissions": ["activeTab", "downloads", "storage", "scripting"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quiz Baker"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
